{
	auto_https off
}

:80 {
	# API
	handle /api/* {
		reverse_proxy backend:8000
	}

	# Django Admin
	handle /admin/* {
		reverse_proxy backend:8000
	}

	# WebSocket — routed to Rust gateway
	handle /ws/* {
		reverse_proxy gateway:8080 {
			transport http {
				versions 1.1
			}
		}
	}

	# Static files
	handle /static/* {
		root * /srv
		file_server
	}

	# Media files
	handle /media/* {
		root * /srv
		file_server
	}

	# Frontend (Next.js) — catch-all
	handle {
		reverse_proxy frontend:3000
	}
}
